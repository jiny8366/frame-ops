# GENIUS OPTICAL CRM — 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 실제 값 입력

# FRAME OPS — 전표·판매일 선택 가능한 가장 이른 날짜 (YYYY-MM-DD, 선택)
# Streamlit Cloud 배포 시에는 .streamlit/secrets.toml 에도 동일 키 설정 가능
FRAME_OPS_DATA_START_DATE=2026-04-01

# Supabase (필수) — FRAME OPS / GENIUS 공통
# 운영·실서버 DB: 대시보드 Project Settings → API 의 Project URL / service_role key 사용
#
# (선택) 터미널에서 psql로 마이그레이션 적용 시만 — Database → Connection string → URI 를 그대로 복사.
# 직접 만든 postgresql://...@db.<ref>.supabase.co 는 DNS에 없는 경우가 많음. 대시보드 URI 사용.
# DATABASE_URL=postgresql://...
SUPABASE_URL=https://여기에프로젝트ID.supabase.co
# 서비스 롤 secret — 본사·스태프·권한 페이지에서 Auth 계정 생성·삭제·전체 목록에 필수 (anon과 별도)
SUPABASE_SERVICE_ROLE_KEY=eyJ...서비스롤키
# anon public 키 — POS 판매 시 담당자 비밀번호 확인(sign_in)에 필요 (서비스 롤과 별도)
SUPABASE_ANON_KEY=eyJ...anon키
# 개발용 단일 키만 쓸 때: anon을 여기 넣어도 됨. 이 경우에도 계정 생성은 위 SUPABASE_SERVICE_ROLE_KEY가 추가로 필요
SUPABASE_KEY=eyJ...anon키
# 로컬 Supabase CLI(http://127.0.0.1:54321)는 개발 전용. 배포 서버에서는 위 호스팅 URL만 쓰는 것을 권장.
# 배포 시 로컬 URL로의 오기입을 막으려면:
# FRAME_OPS_REQUIRE_HOSTED_SUPABASE=1

# Anthropic Claude (필수)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google Gemini (선택)
GEMINI_API_KEY=AIza...

# OpenAI (선택)
OPENAI_API_KEY=sk-...

# FRAME OPS — 로컬 시연(명안당 등): 지점 콤보 기본값·사이드바 "로컬뷰" 배지 (선택)
# FRAME_OPS_PREFERRED_STORE_CODE=BKC01
# FRAME_OPS_LOCAL_VIEW_LABEL=명안당
# FRAME OPS 전용 로컬 포트 (기본 8502, GENIUS CRM 8501 과 분리). run_frame_ops.* 가 사용
# FRAME_OPS_SERVER_PORT=8502


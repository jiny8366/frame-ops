# FRAME OPS / Streamlit 배포용 시크릿 예시
#
# 로컬: 이 파일을 복사해 secrets.toml 로 저장 (secrets.toml 은 git 에 올리지 마세요)
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Streamlit Community Cloud: 앱 설정 → Secrets 에 TOML 그대로 붙여넣기
#
# Supabase 대시보드 → Project Settings → API 에서 Project URL / service_role 복사

SUPABASE_URL = "https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# POS 담당자 비밀번호 확인용 — 대시보드 API 의 anon public 키 (서비스 롤과 다름)
SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 선택: 전표 시작일 (미설정 시 코드 기본값)
# FRAME_OPS_DATA_START_DATE = "2026-04-01"

# 선택: 호스팅 URL만 허용 (로컬 Supabase URL이면 앱 기동 거부)
# FRAME_OPS_REQUIRE_HOSTED_SUPABASE = "1"

# 선택: 본사·스태프·권한 페이지(계정·권한 변경) 잠금 — 미설정이면 PIN 없이 동작(로컬용)
# FRAME_OPS_HQ_PIN = "your-pin"

# 평면 키 대신 묶어 쓰려면 아래만 사용해도 됩니다 (코드가 둘 다 지원).
# [supabase]
# url = "https://YOUR_PROJECT_REF.supabase.co"
# service_role_key = "eyJ..."

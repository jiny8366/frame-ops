# ============================================================
# Funnyview Pickup - 환경변수 템플릿
# 실제 값은 .env.local 에 작성 (절대 커밋 금지)
# ============================================================

# ---------- Database (PostgreSQL) ----------
# 예) postgresql://user:password@host:5432/funnyview_pickup
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/funnyview_pickup

# Read replica (선택, 대용량 트래픽 분산용)
DATABASE_REPLICA_URL=

# Connection pool (PgBouncer 권장)
DATABASE_POOL_MAX=20

# ---------- Redis ----------
# 캐시 + Pub/Sub (주문 알림 실시간 전달)
REDIS_URL=redis://localhost:6379

# ---------- Auth ----------
# 32바이트 이상 랜덤 시크릿 (openssl rand -base64 32)
JWT_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=funnyview_pickup_session
SESSION_MAX_AGE_DAYS=30

# ---------- App ----------
NEXT_PUBLIC_APP_NAME=Funnyview Pickup
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# ---------- OAuth 소셜 로그인 ----------
# 각 provider 개발자 콘솔에서 등록 후 채워주세요.
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/oauth/{provider}/callback

# Naver: https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Kakao: https://developers.kakao.com — 카카오 로그인 활성화
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Google: https://console.cloud.google.com — OAuth 2.0 Client (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- 외부 서비스 (추후 연결) ----------
# 결제 PG
PG_PROVIDER=
PG_API_KEY=

# ---------- 알림 채널 (SMS / 카카오 알림톡) ----------
# 'console' (개발 기본) 또는 'solapi' (실제 발송)
NOTIFICATION_PROVIDER=console

# Solapi (https://solapi.com) — NOTIFICATION_PROVIDER=solapi 일 때 필수
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=         # 사전 등록된 발신번호 (010xxxxxxxx)
SOLAPI_KAKAO_PFID=     # 카카오 비즈채널 PF ID (알림톡 사용 시)

# 알림톡 템플릿 ID (비즈채널 콘솔에서 사전 등록)
KAKAO_TPL_ORDER_RECEIVED=
KAKAO_TPL_ORDER_SHIPPED=
KAKAO_TPL_PICKUP_READY=
KAKAO_TPL_PICKUP_COMPLETED=
